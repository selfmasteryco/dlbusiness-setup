+            }
+            
+            if (highest.score >= 8) {
+                insights.push(`<strong>💪 Strength: ${highest.name}</strong><br>Your ${highest.name} score of ${highest.score}/10 is exceptional. This is your superpower - lean into it and use it to elevate your other areas.`);
+            }
+            
+            // Overall guidance
