+                'Alignment': alignment,
+                'Discipline': discipline,
+                'Connection': connection,
+                'Legacy': legacy
+            };
+            
+            // Find strongest and weakest
+            let lowest = { name: '', score: 11 };
+            let highest = { name: '', score: 0 };
+            
+            for (let [name, score] of Object.entries(scores)) {
+                if (score < lowest.score) {
